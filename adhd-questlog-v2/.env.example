# ============================================================
# QUESTLOG — Environment Variables
# 1. Copy this file: cp .env.example .env
# 2. Fill in your Supabase project keys below
# 3. Get them from: Supabase Dashboard → Project Settings → API
# ============================================================

# Your Supabase project URL (looks like: https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Your Supabase anon/public key (safe to use in frontend code)
VITE_SUPABASE_ANON_KEY=

# ── Without these keys, the app runs in local-only mode ────
# Everything works offline — Supabase just won't sync.

# ── Local development only — never set this on GitHub ───────
# Set to true to bypass login entirely (useful when Supabase is down)
VITE_OFFLINE_MODE=false
